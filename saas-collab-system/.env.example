DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-dev-only
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# MySQL is the standard database target. Values below are examples only.
DB_ENGINE=django.db.backends.mysql
DB_NAME=saas_collab_dev
DB_USER=saas_collab_user
DB_PASSWORD=change-me-db-password
DB_HOST=mysql
DB_PORT=3306

# Docker MySQL 8 example variables. Do not use real production secrets here.
MYSQL_DATABASE=saas_collab_dev
MYSQL_USER=saas_collab_user
MYSQL_PASSWORD=change-me-db-password
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=change-me-root-password

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
