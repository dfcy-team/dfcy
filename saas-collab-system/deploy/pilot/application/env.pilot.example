# Copy to .env.pilot on the controlled pilot host. Do not commit .env.pilot.
PILOT_ENVIRONMENT_CODE=controlled-pilot
PILOT_RELEASE_GIT_SHA=change-me-40-character-approved-main-commit
PILOT_ARTIFACT_MANIFEST_FILE=/etc/saas-collab/promotion/sandbox-artifact-manifest.json
PILOT_SANDBOX_EVIDENCE_FILE=/etc/saas-collab/promotion/sandbox-verification-evidence.json
PILOT_BACKEND_IMAGE=ghcr.io/dfcy-team/dfcy/saas-collab-backend@sha256:change-me-64-character-sandbox-verified-digest
PILOT_FRONTEND_IMAGE=ghcr.io/dfcy-team/dfcy/saas-collab-frontend@sha256:change-me-64-character-sandbox-verified-digest
PILOT_REDIS_IMAGE=redis@sha256:change-me-64-character-approved-digest
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_SECRET_KEY=change-me-generate-a-unique-pilot-secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=change-me-application-host-ip,localhost,backend
CORS_ALLOWED_ORIGINS=https://change-me-application-hostname:8443

DB_ENGINE=django.db.backends.mysql
DB_NAME=saas_collab_pilot
DB_USER=saas_collab_pilot_user
DB_PASSWORD=change-me-mysql-user-password
DB_HOST=change-me-database-host-ip
DB_PORT=3306

REDIS_PASSWORD=change-me-redis-password
REDIS_URL=redis://:change-me-redis-password@redis:6379/0
CELERY_BROKER_URL=redis://:change-me-redis-password@redis:6379/0
CELERY_RESULT_BACKEND=redis://:change-me-redis-password@redis:6379/0
SYNC_JOB_LEASE_SECONDS=900

# Pilot safety: real integration credential storage stays disabled.
INTEGRATION_ENCRYPTION_PROVIDER=unconfigured-production
PILOT_APP_PORT=8000
PILOT_HTTP_PORT=8080
PILOT_HTTPS_PORT=8443
PILOT_TLS_CERT_PATH=/etc/saas-collab/tls/change-me-pilot.crt
PILOT_TLS_KEY_PATH=/etc/saas-collab/tls/change-me-pilot.key
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=60
