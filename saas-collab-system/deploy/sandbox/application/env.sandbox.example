# Copy to .env.sandbox on the isolated Sandbox application host. Do not commit .env.sandbox.
SANDBOX_ENVIRONMENT_CODE=sandbox
SANDBOX_RELEASE_GIT_SHA=change-me-40-character-main-commit
SANDBOX_ARTIFACT_MANIFEST_FILE=/etc/saas-collab/sandbox-artifact-manifest.json
SANDBOX_VERIFICATION_EVIDENCE_FILE=/var/lib/saas-collab/evidence/sandbox-verification-evidence.json
SANDBOX_APP_RUNTIME_NETWORK_EVIDENCE_FILE=/var/lib/saas-collab/network/app-runtime-network-evidence.json
SANDBOX_APP_POST_REBOOT_EVIDENCE_FILE=/var/lib/saas-collab/network/app-post-reboot-evidence.json
SANDBOX_DB_POST_REBOOT_EVIDENCE_FILE=/var/lib/saas-collab/evidence/db-post-reboot-evidence.json
SANDBOX_UNAPPROVED_DB_SOURCE_EVIDENCE_FILE=/var/lib/saas-collab/evidence/unapproved-db-source-evidence.json
SANDBOX_DB_REJECT_COUNTER_EVIDENCE_FILE=/var/lib/saas-collab/evidence/db-unapproved-source-reject-evidence.json
SANDBOX_E2E_SCOPE_PROBE_CODE=sandbox-scope-probe
SANDBOX_BACKEND_IMAGE=ghcr.io/dfcy-team/dfcy/saas-collab-backend@sha256:change-me-64-character-digest
SANDBOX_FRONTEND_IMAGE=ghcr.io/dfcy-team/dfcy/saas-collab-frontend@sha256:change-me-64-character-digest
SANDBOX_REDIS_IMAGE=redis@sha256:change-me-64-character-approved-digest
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_SECRET_KEY=change-me-generate-a-unique-sandbox-secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=sandbox.example.internal,localhost,backend
CORS_ALLOWED_ORIGINS=https://sandbox.example.internal:8543

DB_ENGINE=django.db.backends.mysql
DB_NAME=saas_collab_sandbox
DB_USER=saas_collab_sandbox_user
DB_PASSWORD=change-me-sandbox-mysql-user-password
DB_HOST=change-me-sandbox-database-host-ip
DB_PORT=3307

REDIS_PASSWORD=change-me-sandbox-redis-password
REDIS_URL=redis://:change-me-sandbox-redis-password@redis:6379/0
CELERY_BROKER_URL=redis://:change-me-sandbox-redis-password@redis:6379/0
CELERY_RESULT_BACKEND=redis://:change-me-sandbox-redis-password@redis:6379/0
SYNC_JOB_LEASE_SECONDS=300

# Sandbox safety gates. These values are mandatory and must remain unchanged.
INTEGRATION_ENCRYPTION_PROVIDER=unconfigured-production
SANDBOX_ALLOW_REAL_PLATFORM=false
SANDBOX_ALLOW_HIGH_RISK_AUTOMATION=false

SANDBOX_PUBLIC_HOST=sandbox.example.internal
SANDBOX_APP_PORT=8100
SANDBOX_HTTP_PORT=8180
SANDBOX_HTTPS_PORT=8543
SANDBOX_TLS_CERT_PATH=/etc/saas-collab/sandbox-tls/change-me-sandbox.crt
SANDBOX_TLS_KEY_PATH=/etc/saas-collab/sandbox-tls/change-me-sandbox.key
SANDBOX_CA_CERT_PATH=/etc/saas-collab/sandbox-tls/change-me-sandbox-ca.crt
SANDBOX_NETWORK_POLICY_FILE=/etc/saas-collab/sandbox-network.env
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=60
