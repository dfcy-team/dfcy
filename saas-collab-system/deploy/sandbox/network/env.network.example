# Copy to /etc/saas-collab/sandbox-network.env on both Sandbox hosts.
SANDBOX_NETWORK_APPLY=change-me-set-YES-after-review
SANDBOX_APP_HOST_IP=change-me-private-application-ip
SANDBOX_DB_HOST_IP=change-me-private-database-ip
SANDBOX_DB_PORT=3307
SANDBOX_CLIENT_CIDR=change-me-approved-client-cidr
SANDBOX_NETWORK_STATE_DIR=/var/lib/saas-collab/network
# Set to YES only on an independent, unapproved probe host after change approval.
SANDBOX_UNAPPROVED_SOURCE_PROBE=change-me-set-YES-on-probe-host
