# Copy to .env.sandbox on the isolated Sandbox database host. Do not commit .env.sandbox.
SANDBOX_ENVIRONMENT_CODE=sandbox
SANDBOX_MYSQL_IMAGE=mysql@sha256:change-me-64-character-approved-digest
MYSQL_DATABASE=saas_collab_sandbox
MYSQL_USER=saas_collab_sandbox_user
MYSQL_PASSWORD=change-me-sandbox-mysql-user-password
MYSQL_ROOT_PASSWORD=change-me-sandbox-mysql-root-password
SANDBOX_DB_BIND_IP=change-me-sandbox-database-host-ip
SANDBOX_DB_PORT=3307
SANDBOX_NETWORK_POLICY_FILE=/etc/saas-collab/sandbox-network.env
